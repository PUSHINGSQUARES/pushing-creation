#!/usr/bin/env python3
"""Manage API keys in macOS Keychain for pushing-creation providers."""
import argparse
import getpass
import sys
from pathlib import Path

_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(_ROOT))

from lib import keychain
from lib import scrub as scrub_mod
from lib.providers import REGISTRY, get_provider


def cmd_add(provider: str):
    print(f"Adding key for {provider} (com.shadow.control / apiKey_{provider})")
    print("Paste your API key and press Enter (input is hidden):")
    value = getpass.getpass(prompt="")
    if not value.strip():
        print("error: empty key — aborted", file=sys.stderr)
        sys.exit(1)
    try:
        keychain.set_key(provider, value.strip())
    except Exception as e:
        print(f"error: {scrub_mod.scrub(str(e))}", file=sys.stderr)
        sys.exit(1)
    print(f"[ok] {provider} — key stored in Keychain")
    print("Verify with: frames-keys test " + provider)


def cmd_list():
    providers = keychain.list_providers()
    if not providers:
        print("No pushing-creation keys found in Keychain.")
        print("Add one with: frames-keys add <provider>")
        return
    print("Provider keys in Keychain (names only — no values shown):")
    for name in providers:
        tag = "(not in provider registry)" if name not in REGISTRY else ""
        print(f"  {name}  {tag}")


def cmd_test(provider: str):
    if not keychain.has_key(provider):
        print(f"[fail] {provider}: no key in Keychain")
        print(f"  Add with: frames-keys add {provider}")
        sys.exit(1)

    try:
        p = get_provider(provider)
    except ValueError as e:
        print(f"[fail] {provider}: {e}", file=sys.stderr)
        sys.exit(1)

    api_key = keychain.get_key(provider)
    # seedance shares Volcengine credentials with seedream
    if api_key is None and provider == "seedance":
        api_key = keychain.get_key("seedream")
    if api_key is None:
        print(f"[fail] {provider}: key read returned empty", file=sys.stderr)
        sys.exit(1)

    try:
        ok = p.ping(api_key)
    except NotImplementedError:
        print(f"[skip] {provider}: ping not implemented for this provider")
        return
    except Exception as e:
        print(f"[fail] {provider}: {scrub_mod.scrub(str(e))}")
        sys.exit(1)

    if ok:
        print(f"[ok] {provider}")
    else:
        print(f"[fail] {provider}: key rejected or unreachable")
        sys.exit(1)


def cmd_remove(provider: str):
    if not keychain.has_key(provider):
        print(f"No key found for '{provider}' — nothing to remove.")
        return
    removed = keychain.remove_key(provider)
    if removed["primary"]:
        print(f"[ok] Removed primary key (com.shadow.control / apiKey_{provider}) from Keychain.")
    if removed["fallback"]:
        print(f"[ok] Removed legacy key (pushing-creation:{provider}) from Keychain.")
    if not removed["primary"] and not removed["fallback"]:
        print(f"error: failed to remove key for '{provider}'", file=sys.stderr)
        sys.exit(1)


def build_arg_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="frames-keys",
        description="Manage pushing-creation provider API keys in macOS Keychain.",
    )
    sub = p.add_subparsers(dest="command")

    add_p = sub.add_parser("add", help="Add or update a provider key")
    add_p.add_argument("provider", help="Provider name (gemini, openai, kling, ...)")

    sub.add_parser("list", help="List all stored pushing-creation services")

    test_p = sub.add_parser("test", help="Test a provider key with a live ping")
    test_p.add_argument("provider", help="Provider name")

    rm_p = sub.add_parser("remove", help="Remove a provider key from Keychain")
    rm_p.add_argument("provider", help="Provider name")

    return p


def main():
    parser = build_arg_parser()
    args = parser.parse_args()

    if args.command == "add":
        cmd_add(args.provider)
    elif args.command == "list":
        cmd_list()
    elif args.command == "test":
        cmd_test(args.provider)
    elif args.command == "remove":
        cmd_remove(args.provider)
    else:
        parser.print_help()
        sys.exit(0)


if __name__ == "__main__":
    main()
